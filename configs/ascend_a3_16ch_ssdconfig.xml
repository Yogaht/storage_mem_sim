<!--
  ╔══════════════════════════════════════════════════════════════════════════╗
  ║            Huawei Ascend A3 16CH — Enterprise NVMe SSD Config            ║
  ╚══════════════════════════════════════════════════════════════════════════╝

  ── 资料来源 ─────────────────────────────────────────────────────────────
  · YMTC 232L Xtacking 3.0 3D TLC NAND (YMTC = 长江存储)
    IEICE 2023-2024 paper: "A 232-layer Xtacking 3.0 3D TLC NAND Flash"
    关键参数: 6-plane (2×3 Center X-DEC), 16 KB page, tR=37/45/37 µs
  · Memblaze PBlaze7 7A46 (国产企业级 NVMe SSD, 参考对标)
    PCIe Gen5 ×4, ~16 GB/s host interface, ~15 TB capacity class
  · 华为昇腾 A3 服务器 SSD 子系统 — 16CH 旗舰控制器

  ── NAND 几何 ─────────────────────────────────────────────────────────────
    CHANNELS          = 16        flash 通道数
    CHIPS_PER_CH      =  4        每通道 NAND 封装数 (Chip / Way)
    DIES_PER_CHIP     =  2        每封装晶粒数
    PLANES_PER_DIE    =  6        每晶粒平面数 (YMTC 232L: 2×3 Center X-DEC)
    ─────────────────────────────────────────
    TOTAL_DIES        = 16×4×2 = 128
    TOTAL_PLANES      = 128×6  = 768

  ── Page / Block / Plane 层级 ─────────────────────────────────────────────
    PAGE_SIZE_BYTES   = 16,384 B (16 KB) + 1,942 B metadata
    PAGES_PER_BLOCK   = 576 (TLC: 192 wordlines × 3 bits/cell)
    BLOCKS_PER_PLANE  = 512 (MQSim 仿真限制, 实际 ~2000+)
    ─────────────────────────────────────────
    每 Block 容量       = 576 × 16 KB ≈ 9.2 MB
    每 Plane 容量       = 512 × 9.2 MB ≈ 4.7 GB
    每 Die 容量         = 6 × 4.7 GB ≈ 28.3 GB
    Raw NAND 总容量     = 128 × 28.3 GB ≈ 3,622 GB ≈ 3.6 TB
    User 容量 (OP=7%)   ≈ 3,622 / 1.07 ≈ 3,385 GB ≈ 3.3 TB
    注: 实际 YMTC 232L 单 die 512 Gb (64 GB), 此处 BLOCKS_PER_PLANE=512
         为 MQSim 仿真内存约束的缩减值

  ── 时序参数 ───────────────────────────────────────────────────────────────
    NAND 读 (tR)       = 37,000 / 45,000 / 37,000 ns (LSB / CSB / MSB)
                         YMTC 232L IEICE 论文值
    NAND 写 (tProg)    = 390,000 ns (TLC, 参考 Samsung PM9A3)
    NAND 擦除 (tErase) = 3,500,000 ns (3D TLC 典型值)
    Channel BW         = 1,000 MB/s/ch (MQSim integer-ns timing limit)
    Total Channel BW   = 16 × 1,000 = 16,000 MB/s = 16.0 GB/s
    Flash 协议          = NVDDR2 (ONFI 3.x timing: CMD=290ns, Setup=30ns)
                         注: YMTC 232L 支持 NVDDR3 (ONFI 4.x, 2400 MT/s),
                         MQSim 不支持 NVDDR3, 故降级使用 NVDDR2
    P/E Cycles         = 3,000 (企业级 TLC)

  ── Host 接口 ──────────────────────────────────────────────────────────────
    PCIe Gen5 ×4       ≈ 16 GB/s (4 lanes × 4 GB/s/lane)
    NVMe Queue Depth   = 65,535
    DRAM Cache         = 2 GB (ADVANCED, SHARED)
    CMT (Cache Mapping Table) = 16M entries (与容量成比例)

  ── FTL / GC 配置 ──────────────────────────────────────────────────────────
    Address Mapping    = PAGE_LEVEL
    Plane Allocation   = CWDP (Channel → Way/Chip → Die → Plane)
    GC Policy          = RGA (Greedy), threshold 5%, hard threshold 0.5%
    Overprovisioning   = 7%
    Wear Leveling      = Dynamic + Static (threshold 100)

  ── 理论性能 (CWDP Pipeline Model, pymqsim.trace) ─────────────────────────
    公式: BusTime = CMD + Setup + DataOut
          DataOut = (ReqSize/2) × (2000/CH_BW_MBps) ns
          DiesPerCH = CHIPS_PER_CH × DIES_PER_CHIP
          PipeCycle = max(tR, DiesPerCH × BusTime)
          IOPS = TOTAL_DIES × 1e9 / PipeCycle
          BW   = IOPS × ReqSize / 1e6 (MB/s)
          BusUtil = DiesPerCH×DataOut / PipeCycle

    ReqSize   IOPS           BW               BusUtil   判定
    ─────────────────────────────────────────────────────────────
      4 KB    3,459,459     14,170 MB/s (14.2 GB/s)   88.6%   过渡区
      8 KB    1,879,699     15,398 MB/s (15.4 GB/s)   96.2%   BW-Bound
     16 KB      957,854     15,693 MB/s (15.7 GB/s)   98.1%   BW-Bound
     32 KB      483,559     15,845 MB/s (15.8 GB/s)   99.0%   BW-Bound
    128 KB      121,773     15,961 MB/s (16.0 GB/s)   99.8%   BW-Bound
    ─────────────────────────────────────────────────────────────
    峰值 BW ≈ 16.0 GB/s (受单通道速率与 PCIe Gen5 ×4 上限共同约束)

    解读: 4KB 已接近通道带宽上限，8KB 及以上主要为 BW-Bound。
          16KB 恰好等于 NAND page size, 无读放大。

-->
<Execution_Parameter_Set>
    <Host_Parameter_Set>
        <!-- PCIe Gen5 ×4: ~4 GB/s/lane → ~16 GB/s total (Memblaze PBlaze7 7A46 class) -->
        <PCIe_Lane_Bandwidth>4.00000</PCIe_Lane_Bandwidth>
        <PCIe_Lane_Count>4</PCIe_Lane_Count>
        <SATA_Processing_Delay>400000</SATA_Processing_Delay>
        <Enable_ResponseTime_Logging>false</Enable_ResponseTime_Logging>
        <ResponseTime_Logging_Period_Length>1000000</ResponseTime_Logging_Period_Length>
    </Host_Parameter_Set>
    <Device_Parameter_Set>
        <Seed>321</Seed>
        <Enabled_Preconditioning>false</Enabled_Preconditioning>
        <Memory_Type>FLASH</Memory_Type>
        <HostInterface_Type>NVME</HostInterface_Type>
        <IO_Queue_Depth>65535</IO_Queue_Depth>
        <Queue_Fetch_Size>512</Queue_Fetch_Size>
        <Caching_Mechanism>ADVANCED</Caching_Mechanism>
        <Data_Cache_Sharing_Mode>SHARED</Data_Cache_Sharing_Mode>
        <!-- DRAM write cache: 2 GB -->
        <Data_Cache_Capacity>2147483648</Data_Cache_Capacity>
        <Data_Cache_DRAM_Row_Size>8192</Data_Cache_DRAM_Row_Size>
        <Data_Cache_DRAM_Data_Rate>100</Data_Cache_DRAM_Data_Rate>
        <Data_Cache_DRAM_Data_Busrt_Size>1</Data_Cache_DRAM_Data_Busrt_Size>
        <Data_Cache_DRAM_tRCD>13</Data_Cache_DRAM_tRCD>
        <Data_Cache_DRAM_tCL>13</Data_Cache_DRAM_tCL>
        <Data_Cache_DRAM_tRP>13</Data_Cache_DRAM_tRP>
        <Address_Mapping>PAGE_LEVEL</Address_Mapping>
        <Ideal_Mapping_Table>false</Ideal_Mapping_Table>
        <!-- CMT: 16M entries (doubled from 8CH 8M, proportional to capacity) -->
        <CMT_Capacity>16777216</CMT_Capacity>
        <CMT_Sharing_Mode>SHARED</CMT_Sharing_Mode>
        <Plane_Allocation_Scheme>CWDP</Plane_Allocation_Scheme>
        <Transaction_Scheduling_Policy>PRIORITY_OUT_OF_ORDER</Transaction_Scheduling_Policy>
        <Overprovisioning_Ratio>0.07</Overprovisioning_Ratio>
        <GC_Exec_Threshold>0.05000</GC_Exec_Threshold>
        <GC_Block_Selection_Policy>RGA</GC_Block_Selection_Policy>
        <Use_Copyback_for_GC>false</Use_Copyback_for_GC>
        <Preemptible_GC_Enabled>false</Preemptible_GC_Enabled>
        <GC_Hard_Threshold>0.005000</GC_Hard_Threshold>
        <Dynamic_Wearleveling_Enabled>true</Dynamic_Wearleveling_Enabled>
        <Static_Wearleveling_Enabled>true</Static_Wearleveling_Enabled>
        <Static_Wearleveling_Threshold>100</Static_Wearleveling_Threshold>
        <Preferred_suspend_erase_time_for_read>700000</Preferred_suspend_erase_time_for_read>
        <Preferred_suspend_erase_time_for_write>700000</Preferred_suspend_erase_time_for_write>
        <Preferred_suspend_write_time_for_read>100000</Preferred_suspend_write_time_for_read>
        <!-- ════════════════════════════════════════════════════════════ -->
        <!-- NAND Flash: 16CH flagship controller                        -->
        <!-- Total: 16 CH × 4 chip × 2 die × 6 plane = 768 planes        -->
        <!-- ════════════════════════════════════════════════════════════ -->
        <Flash_Channel_Count>16</Flash_Channel_Count>
        <Flash_Channel_Width>1</Flash_Channel_Width>
        <!-- MQSim uses integer-ns channel periods; values above 1000 collapse to 0ns. -->
        <Channel_Transfer_Rate>1000</Channel_Transfer_Rate>
        <Chip_No_Per_Channel>4</Chip_No_Per_Channel>
        <!-- NVDDR2: CMD=290ns, Setup=30ns (ONFI 3.x timing; MQSim does not support NVDDR3) -->
        <Flash_Comm_Protocol>NVDDR2</Flash_Comm_Protocol>
        <Flash_Parameter_Set>
            <!-- YMTC 232L Xtacking 3.0 3D TLC NAND -->
            <Flash_Technology>TLC</Flash_Technology>
            <CMD_Suspension_Support>ERASE</CMD_Suspension_Support>
            <!-- YMTC 232L read latency: LSB/CSB/MSB (IEICE 2023-2024 paper) -->
            <Page_Read_Latency_LSB>37000</Page_Read_Latency_LSB>
            <Page_Read_Latency_CSB>45000</Page_Read_Latency_CSB>
            <Page_Read_Latency_MSB>37000</Page_Read_Latency_MSB>
            <!-- TLC program latency (ref Samsung PM9A3 TLC: ~390 µs) -->
            <Page_Program_Latency_LSB>390000</Page_Program_Latency_LSB>
            <Page_Program_Latency_CSB>390000</Page_Program_Latency_CSB>
            <Page_Program_Latency_MSB>390000</Page_Program_Latency_MSB>
            <!-- Block erase latency (typical 3D TLC: 3.5 ms) -->
            <Block_Erase_Latency>3500000</Block_Erase_Latency>
            <!-- TLC P/E cycles: ~3,000 (YMTC 232L, enterprise grade) -->
            <Block_PE_Cycles_Limit>3000</Block_PE_Cycles_Limit>
            <Suspend_Erase_Time>700000</Suspend_Erase_Time>
            <Suspend_Program_Time>100000</Suspend_Program_Time>
            <!-- YMTC 232L geometry: 6-plane (2×3 Center X-DEC layout) -->
            <Die_No_Per_Chip>2</Die_No_Per_Chip>
            <Plane_No_Per_Die>6</Plane_No_Per_Die>
            <!-- Blocks per plane: 512 (reduced for MQSim memory; see header for guidance) -->
            <Block_No_Per_Plane>512</Block_No_Per_Plane>
            <!-- Pages per block: 576 (typical TLC block, ~9.2 MB) -->
            <Page_No_Per_Block>576</Page_No_Per_Block>
            <!-- Page size: 16 KB + 1,942 B metadata (YMTC 232L, IEICE paper) -->
            <Page_Capacity>16384</Page_Capacity>
            <Page_Metadat_Capacity>1942</Page_Metadat_Capacity>
        </Flash_Parameter_Set>
    </Device_Parameter_Set>
</Execution_Parameter_Set>
